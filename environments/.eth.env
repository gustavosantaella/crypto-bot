

# ── Base de Datos ─────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=crypto-bot
DB_USER=root
DB_PASS=

# ── Modo de Operación ─────────────────────────────────────────────────────────
BOT_MODE=SCALPING

# ── Par y temporalidad ────────────────────────────────────────────────────────
SYMBOL=ETHUSDT
TIMEFRAME=15m
CHECK_INTERVAL=1

# ── Futuros ───────────────────────────────────────────────────────────────────
# Con $20 de saldo, usar LEVERAGE=5 y entradas del 20% asegura cumplir con 
# el mínimo de $5 de notional de Binance de manera segura.
LEVERAGE=5
MARGIN_TYPE=ISOLATED

# ── RSI (Relative Strength Index) ─────────────────────────────────────────────
RSI_PERIOD=14
RSI_OVERSOLD=30
RSI_OVERBOUGHT=70

# ── ATR (Average True Range) — Volatilidad dinámica ───────────────────────────
ATR_PERIOD=14
ATR_SL_MULTIPLIER=1.8
ATR_TP_MULTIPLIER=1.8

# ── ADX (Average Directional Index) — Filtro de fuerza de tendencia ───────────
ADX_PERIOD=14
ADX_THRESHOLD=25.0

# ── EMA (Exponential Moving Average) — Filtro de tendencia macro ──────────────
EMA_FAST_PERIOD=50
EMA_SLOW_PERIOD=100

# ── Trailing Stop (Stop Loss dinámico) ────────────────────────────────────────
USE_TRAILING_STOP=True
TRAILING_TRIGGER_ATR=1.0

# ── DCA (Dollar Cost Averaging) ───────────────────────────────────────────────
DCA_ENABLED=True

# 3 entradas x 20% = 60% del capital ($12) invertido como máximo. Queda $8 de respaldo.
MAX_DCA_ORDERS=1
DCA_ENTRY_SIZE_PCT=0.20

DCA_RSI_LEVEL_2=30
DCA_RSI_LEVEL_3=25
DCA_RSI_LEVEL_4=20
DCA_MIN_DROP_PCT=0.015

# ── Gestión de Riesgo Fallback ────────────────────────────────────────────────
STOP_LOSS_PCT=0.03
TAKE_PROFIT_PCT=0.02

